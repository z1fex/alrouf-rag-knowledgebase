# Alrouf RAG Knowledge Base — Environment Variables

# Set to "true" for mock mode (no API keys needed), "false" for live OpenAI mode
USE_MOCK_LLM=true

# OpenAI API key (only required when USE_MOCK_LLM=false)
OPENAI_API_KEY=

# OpenAI model settings
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Retrieval settings
TOP_K=3
SIMILARITY_THRESHOLD=0.3

# Paths (relative to project root)
DOCUMENTS_DIR=data/documents
VECTORSTORE_DIR=vectorstore
MOCKS_DIR=mocks

# Server settings
HOST=0.0.0.0
PORT=8000
